<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{% if pageTitle %}{{ pageTitle }} - {{ site.title }}{% else %}{{ site.title }}{% endif %}</title>
<meta name="description" content="{{ site.hero_subtitle }}">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400;1,9..144,600&family=Inter:wght@300;400;500;600&family=Silkscreen:wght@400;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/pbf-system.css">
{% block head %}{% endblock %}
<style>
#pbf-gate{position:fixed;top:0;left:0;width:100%;height:100%;background:#000;z-index:99999;display:flex;flex-direction:column;justify-content:center;align-items:center;font-family:Inter,sans-serif}
#pbf-gate h2{color:#fff;font-size:24px;margin-bottom:24px;letter-spacing:2px}
#pbf-gate input{padding:12px 16px;font-size:16px;border:2px solid #333;border-radius:4px;background:#111;color:#fff;width:280px;text-align:center;outline:none;transition:border .2s}
#pbf-gate input:focus{border-color:#666}
#pbf-gate button{margin-top:16px;padding:12px 32px;font-size:16px;border:none;border-radius:4px;background:#fff;color:#000;cursor:pointer;font-weight:600}
#pbf-gate button:hover{opacity:.9}
#pbf-gate #pbf-error{color:#ff4444;margin-top:12px;font-size:14px;min-height:20px}
.pbf-locked body>*{filter:blur(8px);pointer-events:none}
</style>
<script>
(function(){var k="pbf_unlocked";if(localStorage.getItem(k)==="1"){
var s=document.createElement("style");s.textContent="#pbf-gate{display:none!important}";document.head.appendChild(s);return;}
document.documentElement.classList.add("pbf-locked");
window.addEventListener("load",function(){
var g=document.createElement("div");g.id="pbf-gate";
g.innerHTML="<h2>ENTER PASSWORD</h2><input type=\"password\" id=\"pbf-pass\" autocomplete=\"off\"><div id=\"pbf-error\"></div><button id=\"pbf-submit\">ACCESS</button>";
document.body.appendChild(g);
var i=document.getElementById("pbf-pass"),e=document.getElementById("pbf-error"),b=document.getElementById("pbf-submit");
function check(){var v=i.value;if(v==="PBFweb2oo!"){localStorage.setItem(k,"1");var s=document.createElement("style");s.textContent="#pbf-gate{display:none!important}";document.head.appendChild(s);}else{e.textContent="Incorrect password";i.value="";i.focus();}}
b.addEventListener("click",check);
i.addEventListener("keydown",function(ev){if(ev.key==="Enter")check();});
i.focus();
});})();
</script>
</head>
<body>
{% block body %}{% endblock %}
</body>
</html>
