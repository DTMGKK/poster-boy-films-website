---
permalink: /home.html
layout: false
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ site.title }}</title>
<meta name="description" content="{{ site.hero_subtitle }}">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400;1,9..144,600&family=Inter:wght@300;400;500;600&family=Silkscreen:wght@400;700&display=swap" rel="stylesheet">
<style>
/* ── TOKENS — same as design system ──────────────── */
:root {
  --ink:#060608; --navy:#0B1D30; --navy2:#0E2742; --navy3:#152E4A;
  --bone:#F0EAE1; --paper:#F7F4EE;
  --border-l:rgba(11,29,48,0.09); --border-d:rgba(255,255,255,0.08);
  --gold:#F6D96B; --gold2:#FFE27A; --pink:#FF4D66; --mint:#3DDFC0; --lav:#8B7FE8;
  --warm:#5E5A54; --muted:#8A8680;
  --px:"Silkscreen", monospace; --sr:"Fraunces", Georgia, serif; --ss:"Inter", system-ui, sans-serif;
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:var(--ss);background:var(--ink);color:var(--paper);-webkit-font-smoothing:antialiased;overflow-x:hidden;}
a{text-decoration:none;color:inherit;} img{display:block;max-width:100%;} button{font-family:inherit;cursor:pointer;border:none;}

/* Floating cards */
.fc{background:var(--paper);border:1px solid var(--border-l);border-radius:22px;box-shadow:inset 0 1px 0 rgba(255,255,255,0.7),0 4px 16px rgba(11,29,48,0.08),0 16px 48px rgba(11,29,48,0.05);transition:transform 300ms cubic-bezier(0.22,1,0.36,1),box-shadow 300ms;color:var(--ink);}
.fc:hover{transform:translateY(-5px);box-shadow:inset 0 1px 0 rgba(255,255,255,0.7),0 8px 32px rgba(11,29,48,0.15),0 28px 64px rgba(11,29,48,0.07);}
.fc-d{background:rgba(255,255,255,0.035);border:1px solid var(--border-d);border-radius:22px;box-shadow:0 4px 24px rgba(0,0,0,0.28),0 1px 0 rgba(255,255,255,0.04) inset;transition:transform 300ms cubic-bezier(0.22,1,0.36,1),box-shadow 300ms;}
.fc-d:hover{transform:translateY(-5px);box-shadow:0 12px 48px rgba(0,0,0,0.45),0 0 0 1px var(--gold),0 1px 0 rgba(255,255,255,0.04) inset;}

/* Pixel tags */
.ptag{display:inline-block;font-family:var(--px);font-size:7px;letter-spacing:0.06em;padding:4px 8px;border-radius:3px;line-height:1.3;text-transform:uppercase;}
.ptag-mint{color:var(--mint);border:1px solid rgba(61,223,192,0.4);}
.ptag-pink{color:var(--pink);border:1px solid rgba(255,77,102,0.4);}
.ptag-gold{color:var(--gold);border:1px solid rgba(246,217,107,0.4);}
.ptag-lav{color:var(--lav);border:1px solid rgba(139,127,232,0.4);}
.ptag-muted{color:rgba(244,235,221,0.35);border:1px solid rgba(255,255,255,0.12);}

/* Nav */
nav{position:fixed;top:0;left:0;right:0;z-index:300;height:56px;background:rgba(6,6,8,0.94);backdrop-filter:blur(20px);border-bottom:1px solid rgba(255,255,255,0.06);display:flex;align-items:center;justify-content:space-between;padding:0 48px;}
.nav-logo{font-family:var(--px);font-size:10px;color:var(--gold);text-shadow:2px 2px 0 var(--navy2);letter-spacing:0.05em;line-height:1.3;display:flex;flex-direction:column;}
.nav-logo .sub{font-size:6px;color:rgba(246,217,107,0.4);letter-spacing:0.28em;}
.nav-links{display:flex;gap:36px;}
.nav-links a{font-size:13px;font-weight:500;color:rgba(240,234,225,0.5);transition:color 180ms;position:relative;}
.nav-links a::after{content:'';position:absolute;bottom:-2px;left:0;right:0;height:1px;background:var(--gold);transform:scaleX(0);transform-origin:left;transition:transform 200ms cubic-bezier(0.22,1,0.36,1);}
.nav-links a:hover{color:var(--paper);} .nav-links a:hover::after{transform:scaleX(1);}
.nav-cta{font-family:var(--px);font-size:8px;color:var(--mint);border:1.5px solid var(--pink);padding:7px 14px;border-radius:4px;letter-spacing:0.07em;display:flex;align-items:center;gap:6px;transition:background 200ms,color 200ms;}
.nav-cta .ch{color:var(--pink);} .nav-cta:hover{background:var(--pink);color:var(--ink);} .nav-cta:hover .ch{color:var(--ink);}

/* Hero */
.hero{min-height:100vh;padding:120px 64px 100px;background:var(--ink);display:flex;flex-direction:column;align-items:center;justify-content:center;position:relative;overflow:hidden;text-align:center;}
.hero::before{content:'';position:absolute;inset:0;pointer-events:none;background-image:linear-gradient(rgba(14,39,66,0.3) 1px,transparent 1px),linear-gradient(90deg,rgba(14,39,66,0.3) 1px,transparent 1px);background-size:36px 36px;}
.blob{position:absolute;border-radius:50%;filter:blur(100px);pointer-events:none;}
.blob-1{width:500px;height:500px;top:-10%;right:5%;background:rgba(246,217,107,0.07);}
.blob-2{width:400px;height:400px;bottom:0;left:-5%;background:rgba(255,77,102,0.06);}
.blob-3{width:300px;height:300px;top:30%;right:30%;background:rgba(139,127,232,0.05);}
.hero-inner{position:relative;z-index:1;display:flex;flex-direction:column;align-items:center;gap:28px;}
.hero-logo{max-width:440px;width:80%;filter:drop-shadow(0 0 80px rgba(246,217,107,0.2));animation:logoDrop 0.7s cubic-bezier(0.22,1,0.36,1) 0.1s both;}
@keyframes logoDrop{from{opacity:0;transform:scale(0.9) translateY(-20px);}to{opacity:1;transform:none;}}
.hero-headline{font-family:var(--sr);font-size:clamp(28px,3.5vw,52px);font-weight:600;line-height:1.08;letter-spacing:-0.025em;color:var(--paper);max-width:720px;text-wrap:pretty;animation:fadeUp 0.6s ease 0.3s both;}
.hero-headline em{font-style:italic;color:var(--gold);}
@keyframes fadeUp{from{opacity:0;transform:translateY(16px);}to{opacity:1;transform:none;}}
.hero-copy{font-size:17px;line-height:1.65;color:rgba(240,234,225,0.45);max-width:560px;text-wrap:pretty;animation:fadeUp 0.6s ease 0.45s both;}
.hero-actions{display:flex;gap:14px;align-items:center;flex-wrap:wrap;justify-content:center;animation:fadeUp 0.6s ease 0.6s both;}
.btn-pp{display:inline-flex;align-items:center;gap:10px;font-family:var(--px);font-size:11px;color:var(--mint);background:transparent;border:2.5px solid var(--pink);padding:13px 28px;border-radius:6px;letter-spacing:0.07em;position:relative;overflow:hidden;transition:color 280ms;}
.btn-pp::before{content:'';position:absolute;inset:0;background:var(--pink);transform:translateX(-101%);transition:transform 300ms cubic-bezier(0.22,1,0.36,1);}
.btn-pp span{position:relative;z-index:1;} .btn-pp .ch{color:var(--pink);position:relative;z-index:1;transition:color 280ms;}
.btn-pp:hover::before{transform:none;} .btn-pp:hover{color:var(--ink);} .btn-pp:hover .ch{color:var(--ink);}
.btn-ed{display:inline-flex;align-items:center;gap:7px;font-size:14px;font-weight:600;color:rgba(240,234,225,0.6);border:1px solid rgba(255,255,255,0.12);padding:12px 22px;border-radius:999px;transition:color 180ms,border-color 180ms;}
.btn-ed:hover{color:var(--paper);border-color:rgba(255,255,255,0.3);}

/* Sections */
.section{padding:100px 64px;} .s-inner{max-width:1200px;margin:0 auto;}
.s-label{font-family:var(--px);font-size:8px;letter-spacing:0.1em;display:flex;align-items:center;gap:8px;margin-bottom:14px;}
.s-heading{font-family:var(--sr);font-size:clamp(30px,3.5vw,50px);font-weight:600;line-height:1.08;letter-spacing:-0.022em;text-wrap:pretty;}
.s-heading em{font-style:italic;}
.s-sub{font-size:16px;color:var(--warm);margin-top:8px;line-height:1.5;}

/* Ecosystem (now 2 cards) */
.ecosystem{background:var(--bone);} .ecosystem .s-label{color:var(--pink);} .ecosystem .s-heading{color:var(--ink);}
.eco-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px;margin-top:48px;}
.eco-card{padding:32px;display:flex;flex-direction:column;gap:16px;}
.eco-logo-area{height:96px;display:flex;align-items:center;}
.eco-mark{font-family:var(--px);font-size:22px;color:var(--gold);text-shadow:3px 3px 0 var(--navy2);letter-spacing:0.04em;line-height:1.2;}
.eco-mark .sub-mark{font-size:10px;letter-spacing:0.3em;color:rgba(246,217,107,0.5);display:block;margin-top:6px;}
.eco-mark.lavender{color:var(--lav);text-shadow:2px 2px 0 rgba(80,60,180,0.4);}
.eco-mark.lavender .sub-mark{color:rgba(139,127,232,0.5);}
.eco-mark.mint{color:var(--mint);text-shadow:2px 2px 0 rgba(0,60,48,0.6);}
.eco-mark.mint .sub-mark{color:rgba(61,223,192,0.4);}
.eco-mark.pink{color:var(--pink);text-shadow:2px 2px 0 rgba(80,15,30,0.6);}
.eco-name{font-family:var(--sr);font-size:22px;font-weight:600;color:var(--ink);letter-spacing:-0.01em;}
.eco-blurb{font-size:14px;line-height:1.65;color:var(--warm);flex:1;}
.eco-cta{display:inline-flex;align-items:center;gap:6px;font-size:13px;font-weight:600;color:var(--ink);border-bottom:1px solid rgba(11,29,48,0.2);padding-bottom:2px;width:fit-content;transition:gap 180ms;}
.eco-cta:hover{gap:11px;} .eco-cta.lavender{color:var(--navy2);}

/* Slate */
.slate{background:var(--navy);} .slate .s-label{color:var(--mint);} .slate .s-heading{color:var(--paper);} .slate .s-sub{color:rgba(240,234,225,0.4);}
.slate-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-top:48px;}
@media(max-width:1200px){.slate-grid{grid-template-columns:repeat(2,1fr);}}
@media(max-width:600px){.slate-grid{grid-template-columns:1fr;}}
.pcard{border-radius:20px;overflow:hidden;cursor:pointer;display:flex;flex-direction:column;}
.pcard-thumb{height:130px;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;flex-shrink:0;}
.pcard-thumb::after{content:'';position:absolute;inset:0;background:repeating-linear-gradient(90deg,transparent 0,transparent 5px,rgba(0,0,0,0.12) 5px,rgba(0,0,0,0.12) 6px);}
.pcard-thumb-label{font-family:var(--px);font-size:24px;color:rgba(255,255,255,0.12);letter-spacing:-0.02em;position:relative;z-index:1;text-shadow:4px 4px 0 rgba(0,0,0,0.2);}
.pcard-body{padding:16px 18px 18px;flex:1;display:flex;flex-direction:column;gap:10px;}
.pcard-top{display:flex;justify-content:space-between;align-items:flex-start;gap:8px;}
.pcard-formats{display:flex;gap:5px;flex-wrap:wrap;}
.pcard-format{font-size:10px;font-weight:500;color:rgba(240,234,225,0.35);background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.07);padding:2px 8px;border-radius:999px;}
.pcard-title{font-family:var(--px);font-size:12px;color:var(--gold);text-shadow:2px 2px 0 var(--navy2);letter-spacing:0.04em;line-height:1.45;text-transform:uppercase;}
.pcard-hook{font-size:12px;line-height:1.5;color:rgba(240,234,225,0.38);flex:1;}
.pcard-footer{display:flex;justify-content:space-between;align-items:center;border-top:1px solid rgba(255,255,255,0.06);padding-top:10px;margin-top:2px;}
.pcard-link{font-size:11px;font-weight:600;color:var(--gold);display:flex;align-items:center;gap:5px;transition:gap 150ms;}
.pcard:hover .pcard-link{gap:10px;}
.status-dot{width:5px;height:5px;border-radius:50%;animation:pdot 2s ease-in-out infinite;}
@keyframes pdot{0%,100%{opacity:0.4;transform:scale(1);}50%{opacity:1;transform:scale(1.6);}}

/* Method */
.method{background:var(--bone);} .method .s-label{color:var(--pink);} .method .s-heading{color:var(--ink);}
.method-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:20px;margin-top:52px;}
.mstep{padding:32px;display:flex;flex-direction:column;gap:14px;}
.mstep-level{font-family:var(--px);font-size:8px;color:var(--pink);letter-spacing:0.08em;display:flex;align-items:center;gap:8px;}
.mstep-level::before{content:'▶';color:var(--mint);font-size:7px;}
.mstep-title{font-family:var(--sr);font-size:24px;font-weight:600;color:var(--ink);letter-spacing:-0.01em;line-height:1.1;}
.mstep-desc{font-size:14px;line-height:1.65;color:var(--warm);}
.mstep-tag{font-family:var(--px);font-size:7px;color:var(--muted);letter-spacing:0.06em;margin-top:4px;display:flex;align-items:center;gap:6px;}
.mstep.highlight{background:var(--navy);border-color:rgba(255,255,255,0.08);}
.mstep.highlight .mstep-level{color:var(--gold);} .mstep.highlight .mstep-title{color:var(--paper);} .mstep.highlight .mstep-desc{color:rgba(240,234,225,0.5);} .mstep.highlight .mstep-tag{color:rgba(61,223,192,0.5);}

/* Final CTA */
.cta-section{background:var(--ink);padding:120px 64px;text-align:center;position:relative;overflow:hidden;}
.cta-section::before{content:'';position:absolute;inset:0;background-image:linear-gradient(rgba(14,39,66,0.38) 1px,transparent 1px),linear-gradient(90deg,rgba(14,39,66,0.38) 1px,transparent 1px);background-size:30px 30px;pointer-events:none;mask-image:radial-gradient(ellipse 80% 90% at 50% 50%,black 20%,transparent 100%);}
.cta-inner{position:relative;z-index:1;}
.cta-logo{max-width:200px;margin:0 auto 32px;filter:drop-shadow(0 0 48px rgba(246,217,107,0.18));}
.cta-headline{font-family:var(--sr);font-size:clamp(34px,5vw,64px);font-weight:700;color:var(--paper);letter-spacing:-0.03em;line-height:1.04;max-width:560px;margin:0 auto 12px;}
.cta-headline em{color:var(--gold);font-style:italic;}
.cta-sub{font-size:14px;color:rgba(240,234,225,0.3);letter-spacing:0.04em;margin-bottom:52px;}
.cta-actions{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;}
.btn-cream{font-size:15px;font-weight:600;color:var(--ink);background:var(--paper);padding:14px 28px;border-radius:999px;box-shadow:0 0 0 2px var(--ink);transition:background 200ms;}
.btn-cream:hover{background:var(--gold);}

/* Footer */
footer{background:var(--ink);border-top:1px solid rgba(255,255,255,0.06);padding:24px 64px;display:flex;justify-content:space-between;align-items:center;gap:16px;flex-wrap:wrap;}
.footer-px{font-family:var(--px);font-size:7px;color:rgba(61,223,192,0.2);letter-spacing:0.07em;}
.footer-copy{font-size:11px;color:var(--muted);margin-top:3px;}
.footer-links{display:flex;gap:24px;}
.footer-links a{font-size:11px;color:var(--muted);transition:color 150ms;}
.footer-links a:hover{color:var(--paper);}

@media(max-width:1024px){
  nav{padding:0 24px;} .nav-links{display:none;}
  .hero,.section,.cta-section{padding-left:28px;padding-right:28px;}
  .eco-grid{grid-template-columns:1fr;}
  .method-grid{grid-template-columns:1fr;}
  footer{padding:20px 28px;}
}
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-logo"><span>POSTER BOY FILMS</span><span class="sub">I R E L A N D</span></div>
  <div class="nav-links">
    <a href="#ecosystem">Studio</a>
    <a href="#slate">Slate</a>
    <a href="/work-library.html">Work</a>
    <a href="/catalogue.html">Catalogue</a>
    <a href="#contact">Contact</a>
  </div>
  <a href="/index.html" class="nav-cta"><span class="ch">›</span><span>PRESS PLAY</span><span class="ch">‹</span></a>
</nav>

<!-- HERO -->
<section class="hero" id="hero">
  <div class="blob blob-1"></div><div class="blob blob-2"></div><div class="blob blob-3"></div>
  <div class="hero-inner">
    <img class="hero-logo" src="/assets/PBF-Logo-Full.png" alt="Poster Boy Films" />
    <h1 class="hero-headline">{{ site.hero_headline_html | safe }}</h1>
    <p class="hero-copy">{{ site.hero_subtitle }}</p>
    <div class="hero-actions">
      <a href="/index.html" class="btn-pp"><span class="ch">›</span><span>PRESS PLAY</span><span class="ch">‹</span></a>
      <a href="#ecosystem" class="btn-ed">About us →</a>
    </div>
  </div>
</section>

<!-- ECOSYSTEM -->
<section class="section ecosystem" id="ecosystem">
  <div class="s-inner">
    <div class="s-label"><span>✦</span> THE ECOSYSTEM</div>
    <h2 class="s-heading">{{ ecosystem.heading_html | safe }}</h2>
    <p class="s-sub">{{ ecosystem.subtitle }}</p>

    <div class="eco-grid">
      {% for studio in ecosystem.studios %}
      <div class="fc eco-card">
        <div class="eco-logo-area">
          <div class="eco-mark {{ studio.style }}">{{ studio.pixel_logo_text }}<br><span class="sub-mark">{{ studio.pixel_logo_sub }}</span></div>
        </div>
        <div class="eco-name">{{ studio.name }}</div>
        <p class="eco-blurb">{{ studio.description }}</p>
        <a href="{{ studio.cta_link }}" class="eco-cta {{ studio.style }}">{{ studio.cta_label }} →</a>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- CURRENT SLATE -->
<section class="section slate" id="slate">
  <div class="s-inner">
    <div class="s-label"><span style="color:var(--pink)">▶</span> CURRENT SLATE</div>
    <h2 class="s-heading">{{ site.slate_heading }}</h2>
    <p class="s-sub">{{ site.slate_subtitle }}</p>

    <div class="slate-grid">
      {% for project in collections.projects %}
      <div class="fc-d pcard">
        <div class="pcard-thumb" style="background:linear-gradient(135deg,{{ project.data.gradient_start }},{{ project.data.gradient_end }})">
          <span class="pcard-thumb-label">{{ project.data.abbreviation }}</span>
        </div>
        <div class="pcard-body">
          <div class="pcard-top">
            <div class="pcard-formats">
              {% for format in project.data.formats %}<span class="pcard-format">{{ format }}</span>{% endfor %}
            </div>
            <span class="ptag ptag-{{ project.data.status_color }}">{{ project.data.status }}</span>
          </div>
          <div class="pcard-title">{{ project.data.title }}</div>
          <div class="pcard-hook">{{ project.data.hook }}</div>
          <div class="pcard-footer">
            <a class="pcard-link" href="#">Dossier →</a>
            <div class="status-dot" style="background:var(--{{ project.data.accent_color }});animation-delay:{{ loop.index0 * 0.3 }}s"></div>
          </div>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- METHOD -->
<section class="section method" id="method">
  <div class="s-inner">
    <div class="s-label"><span>✦</span> {{ method.overline }}</div>
    <h2 class="s-heading">{{ method.heading_html | safe }}</h2>
    <div class="method-grid">
      {% for step in method.steps %}
      <div class="fc mstep{% if step.highlight %} highlight{% endif %}">
        <div class="mstep-level">{{ step.level }}</div>
        <div class="mstep-title">{{ step.title }}</div>
        <p class="mstep-desc">{{ step.desc }}</p>
        <div class="mstep-tag">{{ step.tag }}</div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- FINAL CTA -->
<section class="cta-section" id="contact">
  <div class="cta-inner">
    <img class="cta-logo" src="/assets/PBF-Logo-Full.png" alt="Poster Boy Films" />
    <h2 class="cta-headline">{{ site.final_cta_headline_html | safe }}</h2>
    <p class="cta-sub">{{ site.final_cta_sub }}</p>
    <div class="cta-actions">
      <a href="mailto:{{ site.contact_email }}" class="btn-pp"><span class="ch">›</span><span>PRESS PLAY</span><span class="ch">‹</span></a>
      <a href="mailto:{{ site.contact_email }}" class="btn-cream">Request Deck</a>
      <a href="mailto:{{ site.contact_email }}" class="btn-ed">Contact Studio →</a>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <div>
    <div class="footer-px">[ STORY WORLD LOADED ✦ ALL SAVES INTACT ]</div>
    <div class="footer-copy">© {{ site.year }} {{ site.title }} Ltd · {{ site.location }} · {{ site.contact_email }}</div>
  </div>
  <div class="footer-links">
    <a href="#ecosystem">Studio</a><a href="#slate">Slate</a><a href="/work-library.html">Work</a><a href="#contact">Contact</a><a href="/admin/">Admin</a>
  </div>
</footer>

</body>
</html>
